{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MedLink-IE artifact provenance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "model_artifacts", "synthetic_data"],
  "properties": {
    "schema_version": {"const": 1},
    "model_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/modelArtifact"}
    },
    "synthetic_data": {"$ref": "#/$defs/syntheticData"}
  },
  "$defs": {
    "checksum": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "commit": {"type": "string", "pattern": "^[a-fA-F0-9]{7,64}$"},
    "modelArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_name", "path", "checksum_sha256", "training_config", "dataset_versions", "code_commit", "seed"],
      "properties": {
        "model_name": {"type": "string", "minLength": 1},
        "parameter_count": {"type": ["integer", "null"], "minimum": 1, "maximum": 9000000000},
        "path": {"type": "string", "minLength": 1},
        "checksum_sha256": {"$ref": "#/$defs/checksum"},
        "training_config": {"type": "object"},
        "dataset_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "code_commit": {"$ref": "#/$defs/commit"},
        "seed": {"type": "integer", "minimum": 0}
      }
    },
    "syntheticData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_name", "generator_version", "path", "checksum_sha256", "generation_config", "dataset_versions", "code_commit", "seed"],
      "properties": {
        "generator_name": {"type": "string", "minLength": 1},
        "generator_version": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "checksum_sha256": {"$ref": "#/$defs/checksum"},
        "generation_config": {"type": "object"},
        "dataset_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "code_commit": {"$ref": "#/$defs/commit"},
        "seed": {"type": "integer", "minimum": 0}
      }
    }
  }
}
